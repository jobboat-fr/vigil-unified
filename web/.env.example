# VIGIL × WinnyWoo frontend (web/) environment.
# Copy to .env for local dev; set the same in the Vercel project (dev.vigil-ai.xyz).

# Supabase — same project the WinnyWoo gateway + VIGIL frontend already use.
# The product pages (Signals/Positions/Orders/Audit/Vault) auth with this session.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# WinnyWoo gateway (Railway). Optional — defaults to the prod URL in src/lib/ww.ts.
VITE_WW_GATEWAY_URL=https://winnywoo-production.up.railway.app

# Hermes dashboard backend (the new OVH container). Only needed if this build
# serves the operator dashboard pages (Sessions/Logs/Models/MCP/Chat) — they
# call /api on this host. Set once the OVH container's host is live, e.g.
# https://vigil-dev-57-130-58-222.nip.io
# HERMES_DASHBOARD_URL=
